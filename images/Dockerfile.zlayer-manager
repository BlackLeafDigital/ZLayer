# ZLayer Manager - Management UI (Leptos SSR + Hydration + Tailwind v4)
#
# Usage:
#   docker build -f images/Dockerfile.zlayer-manager -t zlayer-manager .

# Stage 1: Chef base
FROM lukemathwalker/cargo-chef:latest-rust-1.92 AS chef
WORKDIR /build

# Stage 2: Generate dependency recipe
FROM chef AS planner
COPY . .
RUN cargo chef prepare --recipe-path recipe.json

# Stage 3: Build
FROM chef AS builder

# Install system dependencies
RUN apt-get update && apt-get install -y \
    protobuf-compiler \
    libseccomp-dev \
    pkg-config \
    cmake \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Install wasm target and cargo-leptos
# cargo-leptos auto-downloads the Tailwind v4 CLI when tailwind-input-file
# is configured in Leptos.toml, so no manual Tailwind installation is needed.
RUN rustup target add wasm32-unknown-unknown && \
    cargo install cargo-leptos

# Cook dependencies (cached layer)
COPY --from=planner /build/recipe.json recipe.json
RUN cargo chef cook --release --recipe-path recipe.json

# Copy source and build
COPY . .
RUN --mount=type=cache,target=/root/.cache/cargo-leptos,id=cargo-leptos-cache \
    cd crates/zlayer-manager && cargo leptos build --release

# Runtime stage
# trixie (glibc 2.41) matches the cargo-chef builder's glibc so the
# zlayer-manager binary's GLIBC_2.38+ symbol references resolve at runtime.
# bookworm-slim (glibc 2.36) was too old and produced
# `version 'GLIBC_2.38' not found` at container startup.
FROM debian:trixie-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy the binary
COPY --from=builder /build/target/release/zlayer-manager /app/zlayer-manager

# Copy the site assets (WASM, CSS, JS, etc.)
COPY --from=builder /build/target/site /app/target/site

# Copy hash.txt next to the binary; Leptos reads it from CWD (/app)
# at startup when LEPTOS_HASH_FILES=true. cargo-leptos emits hash.txt
# next to the bin (target/release/hash.txt).
COPY --from=builder /build/target/release/hash.txt /app/hash.txt

ENV ZLAYER_MANAGER_ADDR=0.0.0.0:6677
# LEPTOS_SITE_ADDR overrides the Leptos.toml default (127.0.0.1:6677)
# so the server binds on all interfaces, making it reachable via
# the overlay network from outside the container netns.
ENV LEPTOS_SITE_ADDR=0.0.0.0:6677
ENV LEPTOS_SITE_ROOT=/app/target/site
ENV LEPTOS_OUTPUT_NAME=zlayer-manager
ENV LEPTOS_SITE_PKG_DIR=pkg
ENV LEPTOS_HASH_FILES=true
ENV RUST_LOG=info

EXPOSE 6677

CMD ["/app/zlayer-manager"]
